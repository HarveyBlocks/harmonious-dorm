{
  "name": "harmonious-dorm",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "reload:prisma": "npx prisma generate",
    "dev": "next dev --webpack -p 3000",
    "dev:user": "set NEXT_DIST_DIR=.next-user && next dev --webpack -p 3000",
    "dev:agent": "set NEXT_DIST_DIR=.next-agent && next dev --webpack -p 3011",
    "dev:turbo": "next dev --turbopack -p 3000",
    "dev:clean": "npm run clean:next && next dev --webpack -p 3000",
    "build": "next build",
    "build:turbo": "next build --turbopack",
    "start": "next start -p 3000",
    "prepare:standalone": "node scripts/prepare-standalone.cjs",
    "start:standalone": "npm run prepare:standalone && node .next/standalone/server.js",
    "clean:next": "node -e \"const fs=require('fs'); const p=process.env.NEXT_DIST_DIR||'.next'; fs.rmSync(p,{recursive:true,force:true})\"",
    "clean:next:all": "node -e \"const fs=require('fs'); ['.next','.next-user','.next-agent'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}))\"",
    "typecheck": "npm run check:i18n && tsc --noEmit -p tsconfig.typecheck.json",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed:large": "node scripts/seed-large-data.cjs",
    "seed:d0003": "node scripts/seed-d0003-heavy.cjs",
    "test:backend": "vitest run tests/backend --maxWorkers=1",
    "test:backend:watch": "vitest tests/backend",
    "migrate:enum-values": "node scripts/migrate-enum-values.cjs",
    "check:i18n": "node scripts/check-i18n-integrity.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.3",
    "autoprefixer": "^10.4.27",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.36.0",
    "next": "^16.1.5",
    "postcss": "^8.5.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-toc": "^9.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^4.2.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "prisma": "^6.6.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
